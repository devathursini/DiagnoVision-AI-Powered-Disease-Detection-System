{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Patient, Doctor, or Admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Diagnosis": {
      "title": "Diagnosis",
      "description": "AI-generated medical diagnosis report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "diseaseType": { "type": "string" },
        "prediction": { "type": "string" },
        "confidence": { "type": "number" },
        "severity": { "type": "string", "enum": ["low", "moderate", "high", "critical"] },
        "imageUrl": { "type": "string" },
        "heatmapUrl": { "type": "string" },
        "analysis": { "type": "string" },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "doctorId": { "type": "string" },
        "doctorNotes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "diseaseType", "prediction", "confidence"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled consultation between patient and doctor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["online", "in-person"] },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "dateTime", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profiles for all system users"
    },
    "/diagnoses/{diagnosisId}": {
      "schema": "Diagnosis",
      "description": "AI medical reports"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Consultation schedules"
    }
  }
}
